# Minimal bootable Arch image for composefs-rs deployment. STUB.
#
# Not yet validated. Same contract as the Fedora image. Arch normally uses
# mkinitcpio, but for cbootc we standardize on dracut everywhere.
#
# Build:  podman build -t arch-cfs-minimal:latest -f examples/arch/Containerfile .

# ---------------------------------------------------------------------------
# Stage 0: Build cbootc from source
# ---------------------------------------------------------------------------
FROM rust:1-slim AS builder
WORKDIR /build
COPY Cargo.toml Cargo.lock ./
COPY src/ src/
RUN cargo build --release

# ---------------------------------------------------------------------------
# Stage 1: OS image
# ---------------------------------------------------------------------------
FROM archlinux:latest

RUN pacman -Syu --noconfirm \
        linux linux-firmware \
        systemd udev dbus-broker \
        util-linux coreutils bash \
        networkmanager iproute2 iputils \
        e2fsprogs dosfstools btrfs-progs \
        grub efibootmgr \
        dracut \
        vim less \
    && pacman -Rns --noconfirm mkinitcpio || true \
    && pacman -Scc --noconfirm

# Layout adjustments — same as Fedora.
# Use cp+find instead of mv: container runtime bind-mounts hosts/hostname/resolv.conf.
RUN if [ -d /etc ] && [ ! -L /etc ]; then \
        mkdir /usr/etc && \
        cp -a /etc/. /usr/etc/ && \
        find /etc -mindepth 1 -maxdepth 1 \
            ! -name hosts ! -name hostname ! -name resolv.conf \
            -exec rm -rf {} +; \
    fi
RUN if [ -d /var ] && [ ! -L /var ]; then \
        mkdir -p /usr/share/factory && \
        mv /var /usr/share/factory/var && \
        mkdir /var; \
    fi
RUN mkdir -p /usr/lib/tmpfiles.d && \
    printf 'q /var 0755 - - -\nC /var - - - - -\n' \
        > /usr/lib/tmpfiles.d/00-var-factory.conf

# TODO: composefs dracut module + dracut invocation

# ---------------------------------------------------------------------------
# Install cbootc
# ---------------------------------------------------------------------------
COPY --from=builder /build/target/release/cbootc /usr/bin/cbootc
COPY units/cbootc-update.service units/cbootc-update.timer /usr/lib/systemd/system/
RUN systemctl enable cbootc-update.timer

LABEL containers.bootc=1
LABEL composefs.backend=cfs-rs
LABEL org.opencontainers.image.title="Arch Minimal (composefs-rs)"

CMD ["/sbin/init"]
